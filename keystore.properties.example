# Шаблон конфигурации подписания release-сборки.
#
# Использование:
#   1. Сгенерировать keystore (ОДИН раз; потеря = невозможность обновлять
#      приложение в сторах под тем же ключом — хранить резервную копию
#      вне рабочей машины, например в менеджере паролей / зашифрованном облаке):
#
#      keytool -genkeypair -v \
#        -keystore smarttracker-release.jks \
#        -alias smarttracker \
#        -keyalg RSA -keysize 4096 \
#        -validity 10000
#
#   2. Скопировать этот файл в keystore.properties (корень проекта)
#      и заполнить реальными значениями.
#   3. keystore.properties и *.jks в .gitignore — НЕ коммитить.
#
# Если keystore.properties отсутствует, release собирается неподписанным
# (для CI и машин без доступа к ключу).

# Путь к keystore относительно корня проекта (или абсолютный)
storeFile=smarttracker-release.jks
storePassword=CHANGE_ME
keyAlias=smarttracker
keyPassword=CHANGE_ME
