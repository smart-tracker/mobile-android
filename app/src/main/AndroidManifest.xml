<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Доступ к интернету для Retrofit -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- GPS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Уведомления (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WakeLock: удерживает CPU активным при выключенном экране для работы GPS -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".SmartTrackerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartTracker"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:screenOrientation="sensorPortrait"
            android:theme="@style/Theme.SmartTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GPS Foreground Service — собирает координаты тренировки в фоне.
             stopWithTask="false": сервис продолжает работать когда пользователь
             смахивает приложение из Recents (актуально для Samsung, Xiaomi и др.). -->
        <service
            android:name=".data.location.LocationTrackingService"
            android:foregroundServiceType="location"
            android:stopWithTask="false"
            android:exported="false" />

    </application>

</manifest>
