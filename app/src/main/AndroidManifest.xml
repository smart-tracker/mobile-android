<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Доступ к интернету для Retrofit -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- GPS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Фоновый доступ к геолокации (Android Q+). Запрашивается отдельным шагом ПОСЛЕ Fine/Coarse.
         Нужен чтобы LocationTrackingService получал обновления когда экран выключен. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Уведомления (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WakeLock: удерживает CPU активным при выключенном экране для работы GPS -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Камера — для съёмки фото профиля -->
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".SmartTrackerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartTracker"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:screenOrientation="sensorPortrait"
            android:theme="@style/Theme.SmartTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GPS Foreground Service — собирает координаты тренировки в фоне.
             stopWithTask="false": сервис продолжает работать когда пользователь
             смахивает приложение из Recents (актуально для Samsung, Xiaomi и др.). -->
        <service
            android:name=".data.location.LocationTrackingService"
            android:foregroundServiceType="location"
            android:stopWithTask="false"
            android:exported="false" />

        <!--
            Отключаем автоматическую инициализацию WorkManager через androidx.startup.
            Без этого WorkManagerInitializer запускается ДО Application.onCreate() и создаёт
            WorkManager с дефолтной WorkerFactory — @HiltWorker/@AssistedInject-воркеры
            получают NoSuchMethodException при инстанциировании.
            При наличии Configuration.Provider в SmartTrackerApp WorkManager инициализируется
            лениво при первом вызове WorkManager.getInstance(context) с нашей HiltWorkerFactory.
        -->
        <!-- FileProvider для передачи URI файла камере (TakePicture).
             minSdk=26 → FileProvider обязателен, прямые file:// URI запрещены с API 24. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.smarttracker.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
