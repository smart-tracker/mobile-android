<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Доступ к интернету для Retrofit -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- GPS -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Фоновый доступ к геолокации (Android Q+). Запрашивается отдельным шагом ПОСЛЕ Fine/Coarse.
         Нужен чтобы LocationTrackingService получал обновления когда экран выключен. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Уведомления (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WakeLock: удерживает CPU активным при выключенном экране для работы GPS -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Doze whitelist: позволяет вызывать ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS
         без SecurityException. Нормальное разрешение — выдаётся автоматически.
         Без whitelist Android Doze throttle'ит GPS-обновления в foreground service
         через ~5-10 мин после выключения экрана. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Bluetooth LE — внешние пульсометры (GATT Heart Rate Service 0x180D).
         API 26–30: legacy-пара BLUETOOTH/BLUETOOTH_ADMIN (install-time);
         скану дополнительно нужна геолокация — она уже запрашивается для тренировок.
         API 31+: runtime-пара BLUETOOTH_SCAN/BLUETOOTH_CONNECT.
         neverForLocation: из результатов скана не выводится местоположение —
         освобождает скан от привязки к гео-разрешению. -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- FGS-тип connectedDevice (API 34+): удержание BLE-соединения с пульсометром
         в foreground-сервисе. Бит добавляется в startForeground условно —
         только когда BLUETOOTH_CONNECT выдан и датчик сохранён. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Камера — для съёмки фото профиля -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- allowBackup=false: в облачный/ADB-бэкап иначе уезжает Room-база
         с GPS-треками (история перемещений пользователя открытым текстом)
         и EncryptedSharedPreferences (нечитаемы без Keystore-ключа, но
         вызывают креш при восстановлении на другом устройстве).
         Все значимые данные синхронизируются с сервером — бэкап не нужен. -->
    <application
        android:name=".SmartTrackerApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartTracker"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="sensorPortrait"
            android:theme="@style/Theme.SmartTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GPS Foreground Service — собирает координаты тренировки в фоне.
             stopWithTask="false": сервис продолжает работать когда пользователь
             смахивает приложение из Recents (актуально для Samsung, Xiaomi и др.). -->
        <service
            android:name=".data.location.LocationTrackingService"
            android:foregroundServiceType="location|connectedDevice"
            android:stopWithTask="false"
            android:exported="false" />

        <!--
            Отключаем автоматическую инициализацию WorkManager через androidx.startup.
            Без этого WorkManagerInitializer запускается ДО Application.onCreate() и создаёт
            WorkManager с дефолтной WorkerFactory — @HiltWorker/@AssistedInject-воркеры
            получают NoSuchMethodException при инстанциировании.
            При наличии Configuration.Provider в SmartTrackerApp WorkManager инициализируется
            лениво при первом вызове WorkManager.getInstance(context) с нашей HiltWorkerFactory.
        -->
        <!-- FileProvider для передачи URI файла камере (TakePicture).
             minSdk=26 → FileProvider обязателен, прямые file:// URI запрещены с API 24. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
