<?xml version="1.0" encoding="utf-8"?>
<!--
    Разрешает HTTP (cleartext) только для адреса эмулятора 10.0.2.2
    (localhost хост-машины). Все остальные соединения по-прежнему
    требуют HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
